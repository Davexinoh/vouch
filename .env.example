# agentic AK login (same as onchainos `wallet login` without email).
OKX_ACCESS_TOKEN=

# Payment config
VOUCH_PAYOUT_WALLET=0xcd782ca4a7dbd69f31229cc702292020aa8277c4
USDT_XLAYER_ADDRESS=
VET_PRICE=1000000

# Deploy
SELF_URL=https://vouch.onrender.com
